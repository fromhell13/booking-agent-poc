# Qdrant settings
QDRANT_HOST=localhost
QDRANT_PORT=6333

# Redis settings
REDIS_HOST=localhost
REDIS_PORT=6379

# Ollama settings
OLLAMA_HOST=http://localhost:11434

# Qdrant collection name
COLLECTION_NAME=restaurant_menu

# Embedding model
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Ollama chat model
OLLAMA_CHAT_MODEL=smallthinker # You can change this to any other model you have installed

# Cache Time-To-Live (in seconds)
CACHE_TTL=3600

# PDF Directory
PDF_DIRECTORY=mcp-server/menu

# AgentOps
AGENTOPS_API_KEY=your_api_key_here

# Docker Compose service settings
POSTGRES_USER=booking
POSTGRES_PASSWORD=bookingpass
POSTGRES_DB=bookingdb
POSTGRES_PORT=25432

OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_HTTP_TIMEOUT=600
OLLAMA_NUM_PREDICT=384

QDRANT_PATH=/data/qdrant_local
DATABASE_URL=postgresql+psycopg://booking:bookingpass@postgres:5432/bookingdb
REDIS_URL=redis://redis:6379/0
MENU_CACHE_TTL_SECONDS=3600

MCP_SERVER_PORT=8000
MCP_URL=http://mcp_server:8000/mcp
AGENT_URL=http://agent:8080
AGENT_REQUEST_TIMEOUT=600
STREAMLIT_PORT=8501